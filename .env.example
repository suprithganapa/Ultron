# ============================================================
#  ULTRON — environment configuration
#  Copy this file to ".env" and fill in what you have.
#  ULTRON runs with ZERO keys in "mock" mode, so you can try
#  it first and add a real brain later.
# ============================================================

# --- Which LLM powers ULTRON's brain ---
# Options: mock | openai | gemini | groq | anthropic
LLM_PROVIDER=mock

# --- API keys (only the one for your chosen provider is needed) ---
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- Model names (sensible defaults are used if left blank) ---
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# --- Optional: real web search (falls back to free DuckDuckGo if blank) ---
TAVILY_API_KEY=

# --- Server ---
HOST=127.0.0.1
PORT=8000

# --- Safety: allow ULTRON to run shell commands / code (true/false) ---
# Keep this true only on a machine you trust. Commands are sandboxed to
# the project workspace by default. Auto-disabled when PUBLIC_MODE=true.
ALLOW_SHELL=true
ALLOW_CODE_EXEC=true

# ============================================================
#  DEPLOYMENT & SECURITY (for hosting ULTRON publicly)
# ============================================================

# Turn ON when exposing ULTRON to the internet. Forces login and, by
# default, disables the shell/code-exec tools (remote code execution on a
# public server is dangerous).
PUBLIC_MODE=false

# Login password. Required in public mode. If empty in local mode, no login.
ULTRON_PASSWORD=

# Secret used to sign login tokens. Generate a long random string for prod
# (e.g. `python -c "import secrets;print(secrets.token_hex(32))"`).
ULTRON_SECRET=

# Allowed browser origins for CORS. Use your site URL in prod, e.g.
# https://ultron.onrender.com  (leave as * for local dev).
CORS_ORIGINS=*

# Durable memory. Leave blank to use local SQLite. Set to a Postgres URL
# (postgres://...) on a cloud host so ULTRON never forgets across restarts.
DATABASE_URL=

# Where persistent data is stored (SQLite db, workspace). On a cloud host
# with a mounted disk, point this at that disk, e.g. /data
ULTRON_DATA_DIR=
